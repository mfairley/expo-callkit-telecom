# Hashed VitePress build assets — content-hashed filenames, safe to cache forever.
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Unhashed static assets in /public/. Long cache; bust by renaming if ever updated.
/*.webp
  Cache-Control: public, max-age=31536000, immutable
/*.png
  Cache-Control: public, max-age=31536000, immutable
/*.jpg
  Cache-Control: public, max-age=31536000, immutable
/*.mp4
  Cache-Control: public, max-age=31536000, immutable
/*.woff2
  Cache-Control: public, max-age=31536000, immutable
