# Test-push credentials for send-test-push.ts.
# Copy to `.env` (gitignored) and fill in real values.
#
# Key material itself lives on disk in this directory:
#   apns_key.p8     APNs .p8 auth key (gitignored)
#   fcm_key.json    FCM service-account JSON (gitignored)

# iOS bundle id of the example client (must match example/client/app.config.ts).
# The APNs topic is derived from this as `${BUNDLE_ID}.voip`.
BUNDLE_ID=com.example.expocallkittelecom

# ---- iOS (APNs VoIP) ----
# APNS_DEVICE_TOKEN: copy from the example client's console log.
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_DEVICE_TOKEN=

# ---- Android (FCM v1) ----
# FCM_TOKEN: copy from the example client's console log.
FCM_TOKEN=
