{
  "name": "expo-callkit-telecom",
  "version": "0.3.2",
  "description": "CallKit + Jetpack Core-Telecom for Expo / React Native — native call UI, VoIP push, LiveKit-friendly audio. A modern react-native-callkeep alternative.",
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "exports": {
    ".": {
      "types": "./build/index.d.ts",
      "default": "./build/index.js"
    },
    "./app.plugin": "./app.plugin.js",
    "./app.plugin.js": "./app.plugin.js",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "expo-module build && expo-module build plugin",
    "clean": "expo-module clean",
    "lint": "expo-module lint",
    "test": "expo-module test",
    "typecheck": "tsc --noEmit && tsc --noEmit -p plugin",
    "prepare": "expo-module prepare",
    "prepublishOnly": "expo-module prepublishOnly",
    "expo-module": "expo-module",
    "open:ios": "xed example/client/ios",
    "open:android": "open -a \"Android Studio\" example/client/android",
    "docs:api": "typedoc",
    "docs:dev": "bun run docs:api && vitepress dev docs",
    "docs:build": "bun run docs:api && vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "keywords": [
    "react-native",
    "expo",
    "expo-module",
    "callkit",
    "callkeep",
    "telecom",
    "core-telecom",
    "jetpack",
    "voip",
    "calling",
    "incoming-call",
    "webrtc",
    "livekit",
    "pushkit",
    "apns",
    "fcm",
    "push-notifications"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mfairley/expo-callkit-telecom.git"
  },
  "bugs": {
    "url": "https://github.com/mfairley/expo-callkit-telecom/issues"
  },
  "author": {
    "name": "Michael Fairley",
    "url": "https://github.com/mfairley"
  },
  "license": "MIT",
  "homepage": "https://mfairley.github.io/expo-callkit-telecom/",
  "dependencies": {},
  "devDependencies": {
    "@types/react": "~19.2.14",
    "expo": "^55.0.24",
    "expo-module-scripts": "^55.0.2",
    "react": "19.2.0",
    "react-native": "0.83.6",
    "typedoc": "^0.28.19",
    "typedoc-plugin-markdown": "^4.11.0",
    "vitepress": "^1.6.4"
  },
  "peerDependencies": {
    "expo": "*",
    "react": "*",
    "react-native": "*",
    "expo-notifications": "*",
    "@livekit/react-native-webrtc": ">=144.0.0"
  }
}
